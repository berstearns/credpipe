# credpipe config — copy to .env and fill in. .env is git-ignored; never commit it.
#
# ── REQUIRED ────────────────────────────────────────────────────────────────
# Public host (IP or DNS) of your relay VPS. The only thing you MUST set.
CREDPIPE_HOST=

# ── OPTIONAL (sane defaults shown; uncomment to override) ────────────────────
# TCP ports the relay listens on.
#CREDPIPE_PULL_PORT=9000
#CREDPIPE_PUSH_PORT=9001

# Shared symmetric key. Same bytes on EVERY machine. Never on the relay.
#CREDPIPE_KEY=$HOME/.config/credpipe/key

# The credential file to sync (Claude Code OAuth tokens on Linux).
#CREDPIPE_CREDS=$HOME/.claude/.credentials.json

# Relay-side path where the encrypted blob is stored (only used by `serve`).
#CREDPIPE_BLOB=/srv/credpipe/creds.enc

# Absolute path to the REAL claude binary (only used by `wrap`).
# Find it with: command -v claude   (then make sure the wrapper shadows it on PATH)
#CREDPIPE_REAL_CLAUDE=/usr/local/bin/claude

# ── OPTIONAL: DigitalOcean relay deploy (only for the scripts under setup/) ───
# SSH user for the relay (default root).
#CREDPIPE_VPS_USER=root
# DO cloud firewall id that fronts the relay — used by setup/03-open-ports.sh to
# open the relay ports. Find it with: doctl compute firewall list
#CREDPIPE_DO_FW_ID=
